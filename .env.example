# Copy to .env and fill in real values.
# SLACK_BOT_TOKEN: xoxb-* token from your Slack app's OAuth page.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# SLACK_SIGNING_SECRET: Basic Information -> App Credentials -> Signing Secret.
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: override the gateway port (default 9511).
# PORT=9511

# Optional: override the Slack adapter webhook port (default 9512).
# SLACK_PORT=9512

# Optional: override the gateway URL used by the Slack adapter.
# GATEWAY_URL=http://127.0.0.1:9511
